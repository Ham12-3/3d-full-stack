# ─────────────────────────────────────────────────────────────
# Liveblocks (multiplayer: presence, live cursors, shared state)
# ─────────────────────────────────────────────────────────────
# Where to get these:
#   1. Sign up / log in at https://liveblocks.io
#   2. Open the Dashboard → create (or pick) a project
#   3. Go to the project's "API keys" tab
#
# Public key  → starts with "pk_"  → safe to expose to the browser
# Secret key  → starts with "sk_"  → server-only, NEVER expose to the client
#
# For the MVP we authorize rooms with the public key (simplest path).
# When you add auth later, switch to the secret key in a server route.

# Public key, read by the browser. Must be prefixed NEXT_PUBLIC_ to be exposed.
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_dev_replace_me

# Secret key, server-only. Used by the /api/liveblocks-auth route once you
# add authenticated rooms. Leave as-is for the public-key MVP.
LIVEBLOCKS_SECRET_KEY=sk_dev_replace_me

# ─────────────────────────────────────────────────────────────
# Database (optional — only needed once we add board persistence)
# ─────────────────────────────────────────────────────────────
# Neon Postgres connection string. Get it from https://neon.tech →
# your project → "Connection Details". Not used in the MVP.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
